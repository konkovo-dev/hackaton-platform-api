# Auth Service Configuration

# Database
DB_DSN=postgres://postgres:postgres@localhost:5432/hackaton?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m

# gRPC
AUTH_SERVICE_GRPC_PORT=50057

# JWT
RS256_PRIVATE_KEY_PATH=.keys/private_key.pem
JWT_KEY_ID=key-1
JWT_ISSUER=hackaton-platform
JWT_AUDIENCE=hackaton-platform

# Token TTL
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
IDEMPOTENCY_TTL=24h

# Identity Client (для auth-service outbox)
IDENTITY_SERVICE_URL=localhost:50051

# Outbox
OUTBOX_POLL_INTERVAL=1s
OUTBOX_MAX_ATTEMPTS=3

# Logging
LOG_LEVEL=info

# Identity Service Configuration
IDENTITY_SERVICE_GRPC_PORT=50051

# Auth Client (для identity-service)
AUTH_CLIENT_SERVICE_URL=localhost:50057
AUTH_CLIENT_MAX_CACHE_TTL=60s
AUTH_CLIENT_CACHE_CLEANUP_INTERVAL=1m
