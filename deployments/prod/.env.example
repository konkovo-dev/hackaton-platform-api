# ─────────────────────────────────────────────────────────────────────────────
# Docker Registry & Image Tag
# ─────────────────────────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/konkovo-dev
IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────────────────────
# Postgres
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ─────────────────────────────────────────────────────────────────────────────
# JWT Configuration
# ─────────────────────────────────────────────────────────────────────────────
JWT_KEYS_PATH=/opt/hackplatform/keys

JWT_KEY_ID=prod-key-1
JWT_ISSUER=hackathon-platform
JWT_AUDIENCE=hackathon-platform
ACCESS_TOKEN_TTL=1h
REFRESH_TOKEN_TTL=720h

# ─────────────────────────────────────────────────────────────────────────────
# Service-to-Service Authentication
# ─────────────────────────────────────────────────────────────────────────────
SERVICE_AUTH_TOKEN=CHANGE_ME_RANDOM_TOKEN_MIN_32_CHARS

# ─────────────────────────────────────────────────────────────────────────────
# Centrifugo
# ─────────────────────────────────────────────────────────────────────────────
CENTRIFUGO_JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS

CENTRIFUGO_API_KEY=CHANGE_ME_RANDOM_API_KEY_MIN_32_CHARS

CENTRIFUGO_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

CENTRIFUGO_ADMIN_SECRET=CHANGE_ME_ADMIN_SECRET_MIN_32_CHARS

CENTRIFUGO_ALLOWED_ORIGINS=*

CENTRIFUGO_JWT_TTL=24h
