FROM golang:1.21-alpine AS builder

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /app/submission ./cmd/submission

FROM alpine:latest

WORKDIR /app

RUN apk --no-cache add ca-certificates

COPY --from=builder /app/submission .

RUN adduser -D -u 1000 appuser
USER appuser

EXPOSE 50054

CMD ["./submission"]

