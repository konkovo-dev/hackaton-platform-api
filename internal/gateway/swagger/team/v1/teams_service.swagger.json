          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/{teamId}": {
      "get": {
        "summary": "Get a team",
        "description": "Returns a team and, optionally, its vacancies. Requires the caller to be staff (OWNER/ORGANIZER/MENTOR) or a registered participant. Available starting from the REGISTRATION stage.",
        "operationId": "TeamService_GetTeam",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetTeamResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "includeVacancies",
            "in": "query",
            "required": false,
            "type": "boolean"
          }
        ],
        "tags": [
          "Team"
        ]
      },
      "delete": {
        "summary": "Delete a team",
        "description": "Deletes the team. Only the team captain can perform this action, and only if they are the sole member. Allowed only during the REGISTRATION stage.",
        "operationId": "TeamService_DeleteTeam",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1DeleteTeamResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "idempotencyKey.key",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "Team"
        ]
      },
      "put": {
        "summary": "Update a team",
        "description": "Updates team fields (name, description, is_joinable). Only the team captain can perform this action. Allowed only during the REGISTRATION stage.",
        "operationId": "TeamService_UpdateTeam",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpdateTeamResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TeamServiceUpdateTeamBody"
            }
          }
        ],
        "tags": [
          "Team"
        ]
      }
    }
  },
