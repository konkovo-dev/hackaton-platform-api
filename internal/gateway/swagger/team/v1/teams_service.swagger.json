{
  "swagger": "2.0",
  "info": {
    "title": "team/v1/teams_service.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "team.v1.TeamService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/hackathons/{hackathonId}/teams": {
      "post": {
        "summary": "Create a team",
        "description": "Creates a team in the hackathon and makes the authenticated user its captain. Allowed only during the REGISTRATION stage when team participation is enabled by the hackathon policy.",
        "operationId": "TeamService_CreateTeam",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CreateTeamResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TeamServiceCreateTeamBody"
            }
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/list": {
      "post": {
        "summary": "List teams",
        "description": "Returns a paginated list of teams for the hackathon. Requires the caller to be staff (OWNER/ORGANIZER/MENTOR) or a registered participant. Available starting from the REGISTRATION stage.",
        "operationId": "TeamService_ListTeams",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListTeamsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TeamServiceListTeamsBody"
            }
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/permissions": {
      "get": {
        "summary": "Get team permissions",
        "description": "Returns what team-related actions the authenticated user can perform on this hackathon (create team, manage own team).",
        "operationId": "TeamService_GetTeamPermissions",
        "responses": {
          "200": {
            "description": "A successful response.",
