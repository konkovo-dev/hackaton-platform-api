  "paths": {
    "/v1/hackathons/{hackathonId}/teams/{teamId}/members": {
      "get": {
        "summary": "List team members",
        "description": "Returns the team roster. Requires the caller to be staff (OWNER/ORGANIZER/MENTOR) or a registered participant. Available starting from the REGISTRATION stage.",
        "operationId": "TeamMembersService_ListTeamMembers",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListTeamMembersResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/{teamId}/members/leave": {
      "post": {
        "summary": "Leave a team",
        "description": "Removes the authenticated user from the team. Only non-captain members can leave. This action is allowed outside REGISTRATION (from REGISTRATION through FINISHED), provided team participation is enabled by the hackathon policy.",
        "operationId": "TeamMembersService_LeaveTeam",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1LeaveTeamResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TeamMembersServiceLeaveTeamBody"
            }
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/{teamId}/members/{userId}/kick": {
      "post": {
        "summary": "Kick a team member",
        "description": "Removes a member from the team. Only the team captain can perform this action. Kicking the captain is forbidden. Allowed only during the REGISTRATION stage.",
        "operationId": "TeamMembersService_KickTeamMember",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1KickTeamMemberResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TeamMembersServiceKickTeamMemberBody"
            }
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/{teamId}/transferCaptain": {
      "post": {
        "summary": "Transfer team captainship",
        "description": "Transfers captainship to another team member. Only the current captain can perform this action. Allowed only during the REGISTRATION stage.",
        "operationId": "TeamMembersService_TransferCaptain",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
