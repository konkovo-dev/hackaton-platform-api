            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TeamMembersServiceTransferCaptainBody"
            }
          }
        ],
        "tags": [
          "Team"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/teams/{teamId}/vacancies/upsert": {
      "post": {
        "summary": "Create or update a vacancy",
        "description": "Creates or updates a vacancy for the team. Only the team captain can perform this action. Slots constraints and team size limits are enforced. Allowed only during the REGISTRATION stage.",
        "operationId": "TeamMembersService_UpsertVacancy",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpsertVacancyResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
