  "paths": {
    "/v1/hackathons/{hackathonId}/judging/assign": {
      "post": {
        "summary": "Assign submissions to judges",
        "description": "Manually assigns all final submissions to judges using round-robin algorithm. Each submission gets minimum 3 judges (or all judges if fewer than 3). Idempotent - returns success if already assigned. Only organizers can call this. Available only during JUDGING stage.",
        "operationId": "JudgingService_AssignSubmissionsToJudges",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1AssignSubmissionsToJudgesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/JudgingServiceAssignSubmissionsToJudgesBody"
            }
          }
        ],
        "tags": [
          "Judging"
        ]
      }
    },
