      "get": {
        "summary": "List hackathon staff",
        "description": "Returns all staff members and their roles for the given hackathon. Requires OWNER or MANAGER role.",
        "operationId": "StaffService_ListHackathonStaff",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListHackathonStaffResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "query.q",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.page.pageSize",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "query.page.pageToken",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "query.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "query.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
