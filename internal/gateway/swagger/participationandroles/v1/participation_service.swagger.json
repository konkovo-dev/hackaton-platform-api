  "paths": {
    "/v1/hackathons/{hackathonId}/participations/me": {
      "get": {
        "summary": "Get my participation",
        "description": "Returns the authenticated user's participation record for the given hackathon.",
        "operationId": "ParticipationService_GetMyParticipation",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetMyParticipationResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Participation"
        ]
      },
      "put": {
        "summary": "Update my participation",
        "description": "Updates wished team roles and motivation text for the authenticated user's participation.",
        "operationId": "ParticipationService_UpdateMyParticipation",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpdateMyParticipationResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ParticipationServiceUpdateMyParticipationBody"
            }
          }
        ],
        "tags": [
          "Participation"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/participations/me:switchMode": {
      "post": {
        "summary": "Switch participation mode",
        "description": "Switches the authenticated user between individual and looking-for-team participation modes.",
        "operationId": "ParticipationService_SwitchParticipationMode",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1SwitchParticipationModeResponse"
