            "schema": {
              "$ref": "#/definitions/ParticipationServiceSwitchParticipationModeBody"
            }
          }
        ],
        "tags": [
          "Participation"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/participations/me:unregister": {
      "post": {
        "summary": "Unregister from hackathon",
        "description": "Withdraws the authenticated user from the hackathon. The participation record is soft-deleted.",
        "operationId": "ParticipationService_UnregisterFromHackathon",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UnregisterFromHackathonResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
