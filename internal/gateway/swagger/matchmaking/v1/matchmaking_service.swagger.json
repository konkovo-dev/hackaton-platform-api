  "paths": {
    "/v1/hackathons/{hackathonId}/matchmaking/candidates": {
      "get": {
        "summary": "Get candidate recommendations for team captain",
        "description": "Returns a ranked list of participants that match the team's vacancy requirements. Available during REGISTRATION stage.",
        "operationId": "MatchmakingService_RecommendCandidates",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RecommendCandidatesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "teamId",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "vacancyId",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "Matchmaking"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/matchmaking/teams": {
      "get": {
        "summary": "Get team recommendations for participant",
        "description": "Returns a ranked list of teams that match the participant's skills and desired roles. Available during REGISTRATION and RUNNING stages.",
        "operationId": "MatchmakingService_RecommendTeams",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1RecommendTeamsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "Matchmaking"
        ]
      }
    }
  },
