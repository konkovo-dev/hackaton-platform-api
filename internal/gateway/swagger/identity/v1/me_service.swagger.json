        },
        "contentType": {
          "type": "string"
        },
        "idempotencyKey": {
          "$ref": "#/definitions/v1IdempotencyKey"
        }
      }
    },
    "v1CreateAvatarUploadResponse": {
      "type": "object",
      "properties": {
        "uploadId": {
          "type": "string"
        },
        "uploadUrl": {
          "type": "string",
          "title": "Pre-signed PUT URL"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1CustomSkill": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "v1GetMeResponse": {
      "type": "object",
      "properties": {
        "user": {
          "$ref": "#/definitions/v1User"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Skill"
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1MyContact"
          }
        },
        "visibility": {
          "$ref": "#/definitions/v1VisibilitySettings"
        }
      }
    },
    "v1IdempotencyKey": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        }
      }
    },
    "v1MyContact": {
      "type": "object",
      "properties": {
        "contact": {
          "$ref": "#/definitions/identityV1Contact"
        },
        "visibility": {
          "$ref": "#/definitions/v1VisibilityLevel"
        }
      }
    },
    "v1Skill": {
      "type": "object",
      "properties": {
        "catalog": {
          "$ref": "#/definitions/v1CatalogSkill"
        },
        "custom": {
          "$ref": "#/definitions/v1CustomSkill"
        }
      }
    },
    "v1UpdateMeRequest": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "idempotencyKey": {
          "$ref": "#/definitions/v1IdempotencyKey"
        }
      }
    },
    "v1UpdateMeResponse": {
      "type": "object",
      "properties": {
        "user": {
          "$ref": "#/definitions/v1User"
        }
      }
    },
    "v1UpdateMyContactsRequest": {
      "type": "object",
      "properties": {
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1MyContact"
          }
        },
        "contactsVisibility": {
          "$ref": "#/definitions/v1VisibilityLevel"
        },
        "idempotencyKey": {
          "$ref": "#/definitions/v1IdempotencyKey"
        }
      }
    },
    "v1UpdateMyContactsResponse": {
      "type": "object",
      "properties": {
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1MyContact"
          }
        },
        "visibility": {
          "$ref": "#/definitions/v1VisibilitySettings"
        }
      }
    },
    "v1UpdateMySkillsRequest": {
      "type": "object",
      "properties": {
        "catalogSkillIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "Replace-all semantics:"
        },
        "userSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skillsVisibility": {
          "$ref": "#/definitions/v1VisibilityLevel"
        },
        "idempotencyKey": {
          "$ref": "#/definitions/v1IdempotencyKey"
        }
      }
    },
    "v1UpdateMySkillsResponse": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Skill"
          }
        },
        "visibility": {
          "$ref": "#/definitions/v1VisibilitySettings"
        }
      }
    },
    "v1User": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "avatarUrl": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        }
      }
    },
    "v1VisibilityLevel": {
      "type": "string",
      "enum": [
        "VISIBILITY_LEVEL_UNSPECIFIED",
        "VISIBILITY_LEVEL_PRIVATE",
        "VISIBILITY_LEVEL_PUBLIC"
      ],
      "default": "VISIBILITY_LEVEL_UNSPECIFIED"
    },
    "v1VisibilitySettings": {
      "type": "object",
      "properties": {
        "skills": {
          "$ref": "#/definitions/v1VisibilityLevel"
        },
        "contacts": {
          "$ref": "#/definitions/v1VisibilityLevel"
        }
      }
    }
  }
}
