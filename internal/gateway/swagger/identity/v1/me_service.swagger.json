{
  "swagger": "2.0",
  "info": {
    "title": "identity/v1/me_service.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "identity.v1.MeService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/users/me": {
      "get": {
        "summary": "Get my profile",
        "description": "Returns the authenticated user's full profile including skills, contacts, and visibility settings.",
        "operationId": "MeService_GetMe",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetMeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "Users"
        ]
      },
      "put": {
        "summary": "Update my profile",
        "description": "Updates basic profile fields (first name, last name, avatar URL, timezone) for the authenticated user.",
        "operationId": "MeService_UpdateMe",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpdateMeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1UpdateMeRequest"
            }
          }
        ],
        "tags": [
          "Users"
        ]
      }
    },
    "/v1/users/me/avatar/complete": {
      "post": {
        "summary": "Complete avatar upload",
        "description": "Marks the avatar upload as completed and updates the user's avatar_url after successful upload to S3.",
        "operationId": "MeService_CompleteAvatarUpload",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CompleteAvatarUploadResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CompleteAvatarUploadRequest"
            }
          }
        ],
        "tags": [
          "Users"
        ]
      }
    },
    "/v1/users/me/avatar/upload": {
      "post": {
        "summary": "Create avatar upload",
        "description": "Initiates an avatar upload and returns a pre-signed PUT URL. Validates file type (images only) and size limits.",
        "operationId": "MeService_CreateAvatarUpload",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CreateAvatarUploadResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CreateAvatarUploadRequest"
            }
          }
        ],
        "tags": [
          "Users"
        ]
      }
    },
    "/v1/users/me/contacts": {
      "put": {
        "summary": "Replace my contacts",
        "description": "Replaces the authenticated user's contact list entirely (replace-all semantics). Also updates contacts visibility.",
        "operationId": "MeService_UpdateMyContacts",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpdateMyContactsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1UpdateMyContactsRequest"
            }
          }
        ],
        "tags": [
          "Users"
        ]
      }
    },
    "/v1/users/me/skills": {
      "put": {
        "summary": "Replace my skills",
        "description": "Replaces the authenticated user's skill set entirely (replace-all semantics). Also updates skills visibility.",
        "operationId": "MeService_UpdateMySkills",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1UpdateMySkillsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1UpdateMySkillsRequest"
            }
          }
        ],
        "tags": [
          "Users"
        ]
      }
    }
  },
  "definitions": {
    "identityV1Contact": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/v1ContactType"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1CatalogSkill": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "v1CompleteAvatarUploadRequest": {
      "type": "object",
      "properties": {
        "uploadId": {
          "type": "string"
        },
        "idempotencyKey": {
          "$ref": "#/definitions/v1IdempotencyKey"
        }
      }
    },
    "v1CompleteAvatarUploadResponse": {
      "type": "object",
      "properties": {
        "avatarUrl": {
          "type": "string"
        }
      }
    },
    "v1ContactType": {
      "type": "string",
      "enum": [
        "CONTACT_TYPE_UNSPECIFIED",
        "CONTACT_TYPE_EMAIL",
        "CONTACT_TYPE_TELEGRAM",
        "CONTACT_TYPE_GITHUB",
        "CONTACT_TYPE_LINKEDIN"
      ],
      "default": "CONTACT_TYPE_UNSPECIFIED"
    },
    "v1CreateAvatarUploadRequest": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string"
        },
        "sizeBytes": {
          "type": "string",
