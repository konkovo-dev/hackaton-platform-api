  "paths": {
    "/v1/hackathons/{hackathonId}/participants/{ownerKind}/{ownerId}/final-submission": {
      "get": {
        "summary": "Get final submission",
        "description": "Returns the final submission for a participant or team. Owner can view their own final submission. Staff (owners, organizers, mentors, judges) can view any final submission. Available from RUNNING stage onwards.",
        "operationId": "SubmissionService_GetFinalSubmission",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetFinalSubmissionResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "ownerKind",
            "description": "\"user\" or \"team\"",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "ownerId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "Submissions"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/submissions": {
      "post": {
        "summary": "Create a submission",
        "description": "Creates a new submission for the hackathon. Automatically marks it as final if no other final submission exists. Available only during RUNNING stage.",
        "operationId": "SubmissionService_CreateSubmission",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CreateSubmissionResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SubmissionServiceCreateSubmissionBody"
            }
          }
        ],
        "tags": [
          "Submissions"
        ]
      }
    },
    "/v1/hackathons/{hackathonId}/submissions/list": {
      "post": {
        "summary": "List submissions",
        "description": "Returns submissions for the hackathon. If owner_kind and owner_id are specified, returns submissions for that owner. If not specified, returns submissions for the authenticated user/team. Staff (owners, organizers, mentors, judges) can list submissions for any participant/team. Available from RUNNING stage onwards.",
        "operationId": "SubmissionService_ListSubmissions",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListSubmissionsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SubmissionServiceListSubmissionsBody"
            }
          }
        ],
        "tags": [
          "Submissions"
        ]
      }
    },
