            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SubmissionServiceSelectFinalSubmissionBody"
            }
          }
        ],
        "tags": [
          "Submissions"
        ]
      }
    }
