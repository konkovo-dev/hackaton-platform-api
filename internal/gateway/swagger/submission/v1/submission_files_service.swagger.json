      "post": {
        "summary": "Complete submission file upload",
        "description": "Marks the file upload as completed after successful upload to S3. Available only during RUNNING stage.",
        "operationId": "SubmissionFilesService_CompleteSubmissionUpload",
        "responses": {
          "200": {
            "description": "A successful response.",
