            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "submissionId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SubmissionFilesServiceCreateSubmissionUploadBody"
            }
          }
        ],
        "tags": [
          "Submission Files"
        ]
      }
    },
