          }
        },
        "parameters": [
          {
            "name": "hackathonId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "submissionId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "fileId",
            "in": "path",
            "required": true,
